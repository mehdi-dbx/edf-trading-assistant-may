<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Performance Report</title>
  <style>
    @page { margin: 2cm; }
    body {
      font-family: system-ui, -apple-system, sans-serif;
      font-size: 11pt;
      line-height: 1.5;
      color: #222;
      background: #fff;
      max-width: 800px;
      margin: 0 auto;
      padding: 1rem;
    }
    .header {
      display: flex;
      align-items: center;
      gap: 1rem;
      border-bottom: 1px solid #ddd;
      padding-bottom: 1rem;
      margin-bottom: 1.5rem;
    }
    .header img {
      height: 48px;
      width: auto;
    }
    .header h1 { margin: 0; font-size: 1.25rem; }
    .header .date { color: #666; font-size: 0.9rem; }
    .summary {
      background: #f8f9fa;
      border: 1px solid #eee;
      border-radius: 4px;
      padding: 1rem;
      margin-bottom: 1.5rem;
    }
    .summary h2 { margin-top: 0; font-size: 1rem; }
    .section {
      margin-bottom: 1.5rem;
      border: 1px solid #eee;
      border-radius: 4px;
      padding: 1rem;
    }
    .section h2 { margin-top: 0; font-size: 1rem; }
    .metrics table {
      width: 100%;
      border-collapse: collapse;
    }
    .metrics th, .metrics td {
      text-align: left;
      padding: 0.5rem;
      border-bottom: 1px solid #eee;
    }
    .metrics th { color: #666; font-weight: 500; }
    footer {
      margin-top: 2rem;
      padding-top: 0.5rem;
      border-top: 1px solid #ddd;
      font-size: 0.85rem;
      color: #666;
    }
  </style>
</head>
<body>
  <header class="header">
    <img src="{{ logo_b64 }}" alt="Logo" />
    <div>
      <h1>{{ customer_name }}</h1>
      <span class="date">Generated: {{ generated_at }}</span>
    </div>
  </header>

  <section class="summary">
    <h2>Summary</h2>
    <p>{{ data.summary }}</p>
  </section>

  {% for section in data.sections %}
  <section class="section">
    <h2>{{ section.title }}</h2>
    <p>{{ section.content }}</p>
  </section>
  {% endfor %}

  <section class="metrics">
    <h2>Metrics</h2>
    <table>
      {% for key, value in data.metrics.items() %}
      <tr><th>{{ key }}</th><td>{{ value }}</td></tr>
      {% endfor %}
    </table>
  </section>

  <footer>
    Report generated by Performance Reports Agent — Page <span class="page"></span>
  </footer>
</body>
</html>
